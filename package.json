{
  "name": "wmgid",
  "version": "0.1.0",
  "private": true,
  "description": "What's My Google ID — internal staff tool",
  "type": "module",
  "scripts": {
    "build:css": "tailwindcss -i ./src/styles.css -o ./public/style.css --minify",
    "build:js": "cp node_modules/alpinejs/dist/cdn.min.js public/alpine.js",
    "build:ts": "tsc",
    "build": "npm run build:css && npm run build:js && npm run build:ts",
    "dev:css": "tailwindcss -i ./src/styles.css -o ./public/style.css --watch",
    "dev:ts": "tsx watch --env-file-if-exists=.env src/index.ts",
    "dev": "npm run build:css && npm run dev:ts",
    "start": "node dist/index.js",
    "test": "tsx --test 'src/**/*.test.ts' 'src/**/*.test.tsx'"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/oauth-providers": "^0.7.0",
    "alpinejs": "^3.15.12",
    "google-auth-library": "^9.15.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.0.0",
    "@types/node": "^22.10.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
