# Google OAuth client credentials (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# 32+ random bytes used to HMAC the session cookie. Rotate to invalidate sessions.
# Generate locally with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=

# Public URL the OAuth callback redirects to.
# Production: https://wmgid.<dokku-host>
# Local: the fwd.host tunnel URL pointed at this app.
BASE_URL=http://localhost:3000

# Dokku injects PORT; locally it defaults to 3000 when unset.
# PORT=3000

# Optional. When set, sign-in is restricted to that Google Workspace `hd`.
# When unset, any Google account is accepted.
# ALLOWED_HD=example.com
